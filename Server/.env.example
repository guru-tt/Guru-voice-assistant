# Copy this file to .env and fill in real values. Never commit .env.

# Google Gemini API key (get one free at aistudio.google.com/apikey)
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxx

# Dropbox app access token (read-only scope is enough - see README)
DROPBOX_ACCESS_TOKEN=sl.xxxxxxxxxxxxxxxx

# Path to your Obsidian vault folder INSIDE Dropbox
DROPBOX_VAULT_PATH=/Apps/remotely-save/Guru Automations Vault/Guru Automations Vault

# Port the server listens on (Render sets this automatically, safe to leave)
PORT=3000
